@model EGielda.Models.CartItem

@{
    ViewData["Title"] = "Details";
}

<h2 class="mb-4">Details</h2>

<div class="card shadow-sm p-4 mb-4">
    <h5 class="mb-3">Cart Item Info</h5>
    <p><strong>Cart ID:</strong> #@Model.CartId</p>
    <p><strong>Product:</strong> @Model.Product?.Name</p>
    <p><strong>Quantity:</strong> @Model.Quantity</p>
    <p>
        <strong>Total:</strong>
        @((Model.Quantity * (Model.Product?.Price ?? 0)).ToString("0.00")) zł
    </p>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>