@model EGielda.Models.CartItem

@{
    ViewData["Title"] = "Create";
}

<h2 class="mb-4">Create</h2>

<div class="card shadow-sm p-4" style="max-width: 500px;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="CartId" class="form-label"></label>
            <select asp-for="CartId" class="form-select" asp-items="ViewBag.CartId"></select>
        </div>

        <div class="mb-3">
            <label asp-for="ProductId" class="form-label"></label>
            <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
        </div>

        <div class="mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}