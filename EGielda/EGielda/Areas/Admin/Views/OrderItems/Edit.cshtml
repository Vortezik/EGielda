@model EGielda.Models.OrderItem

@{
    ViewData["Title"] = "Edit";
}

<h2 class="mb-4">Edit</h2>

<div class="card shadow-sm p-4" style="max-width: 500px;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="ProductId" class="form-label"></label>
            <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
        </div>

        <div class="mb-3">
            <label asp-for="OrderId" class="form-label"></label>
            <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId"></select>
        </div>

        <div class="mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
