@model EGielda.Models.OrderItem

@{
    ViewData["Title"] = "Details";
}

<h2>Details</h2>

<div class="card p-4">
    <p><strong>Product:</strong> @Model.Product?.Name</p>
    <p><strong>Order ID:</strong> #@Model.OrderId</p>
    <p><strong>Quantity:</strong> @Model.Quantity</p>
    <p>
        <strong>Total:</strong>
        @((Model.Quantity * (Model.Product?.Price ?? 0)).ToString("0.00")) zł
    </p>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
