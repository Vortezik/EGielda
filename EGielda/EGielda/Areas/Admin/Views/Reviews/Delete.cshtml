@model EGielda.Models.Review

@{
    ViewData["Title"] = "Delete";
}

<h2 class="mb-4 text-danger">Delete</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this review?
</div>

<div class="card shadow-sm p-3 mb-3">
    <p><strong>Product:</strong> @Model.Product?.Name</p>
    <p><strong>User:</strong> @Model.User?.Email</p>
    <p><strong>Rating:</strong> @Model.Rating ⭐</p>
    <p><strong>Content:</strong> @Model.Content</p>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>