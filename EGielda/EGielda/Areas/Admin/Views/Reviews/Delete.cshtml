@model EGielda.Models.Review

@{
    ViewData["Title"] = "Delete";
}

<h1 class="mb-4 text-danger">Delete</h1>

<div class="card shadow-sm p-4">
    <p>Are you sure you want to delete this order?</p>

    <ul class="list-group mb-3">
        <li class="list-group-item"><strong>Product:</strong> @Model.Product?.Name</li>
        <li class="list-group-item"><strong>User:</strong> @Model.User?.Email</li>
        <li class="list-group-item"><strong>Rating:</strong> @Model.Rating ⭐</li>
        <li class="list-group-item"><strong>Content:</strong> @Model.Content</li>
    </ul>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>