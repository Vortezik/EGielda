@model EGielda.Models.Review

@{
    ViewData["Title"] = "Details";
}

<h2>Details</h2>

<div class="card p-4">
    <p><strong>Product:</strong> @Model.Product?.Name</p>
    <p><strong>User:</strong> @Model.User?.Email</p>
    <p><strong>Rating:</strong> @Model.Rating ⭐</p>
    <p>
        <strong>Content:</strong></p>
    <p>@Model.Content</p>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary mt-3">Edit</a>
    <a asp-action="Index" class="btn btn-secondary mt-3">Back</a>
</div>