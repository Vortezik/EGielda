@model EGielda.Models.Order

@{
    ViewData["Title"] = "Details";
    var total = Model.OrderItems.Sum(i => i.Quantity * (i.Product?.Price ?? 0));
}

<h2 class="mb-4">Details</h2>

<div class="card shadow-sm p-4 mb-4">
    <h5 class="mb-3">Order Info</h5>
    <p><strong>Order ID:</strong> #@Model.Id</p>
    <p><strong>User:</strong> @Model.User?.Email</p>
    <p><strong>Date:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
</div>

<div class="card shadow-sm p-4">
    <h5 class="mb-3">Items</h5>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>@item.Product?.Price zł</td>
                        <td>@item.Quantity</td>
                        <td>@(item.Quantity * (item.Product?.Price ?? 0)) zł</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-end mt-3">
        <h5>Total: <span class="text-success">@total zł</span></h5>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary mt-3">Edit</a>
<a asp-action="Index" class="btn btn-secondary mt-3">Back</a>