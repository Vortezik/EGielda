@model EGielda.Models.Product

@{
    ViewData["Title"] = "Delete";
}

<h2 class="mb-4 text-danger">Delete</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this product?
</div>

<div class="card shadow-sm p-3 mb-3">
    <div class="row">
        <div class="col-md-3">
            <img src="@Model.ImageUrl" onerror="this.src='/images/no-image.png'" class="img-fluid rounded" />
        </div>

        <div class="col-md-9">
            <p><strong>Name:</strong> @Model.Name</p>
            <p><strong>Price:</strong> @Model.Price zł</p>
            <p><strong>Category:</strong> @Model.Category?.Name</p>
        </div>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
