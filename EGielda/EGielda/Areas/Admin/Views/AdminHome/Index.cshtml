            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="OrderItems" asp-action="Index" class="text-decoration-none">
            <div class="card text-center p-4 shadow-sm">
                <h5>Order Items</h5>
            </div>
        </a>
