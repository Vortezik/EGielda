<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EGielda</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EGielda.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">EGielda</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Products</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Product" asp-action="Index">Products</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Category" asp-action="Index">Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="Admin" asp-controller="AdminHome" asp-action="Index">Admin</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (ViewData["ShowSidebar"] as bool? == true)
    {
    <div class="container-fluid mt-4">
        <div class="row">

            <aside class="col-md-3 col-lg-2 mb-4">
                 <div class="p-3 bg-white border rounded">

                    <h5 class="mb-3">Search</h5>
                    <input type="text" class="form-control mb-4" placeholder="Search products..." />

                    <h5 class="mb-3">Price</h5>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label">Under 50 zł</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label">50–200 zł</label>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label">200+ zł</label>
                    </div>

                    <h5 class="mb-3">Categories</h5>
                        <div class="list-group mb-3">
                            <a asp-area="" asp-controller="Category" asp-action="Index" class="list-group-item list-group-item-action"> Electronics </a>
                            <a asp-area="" asp-controller="Category" asp-action="Index" class="list-group-item list-group-item-action"> Clothing </a>
                            <a asp-area="" asp-controller="Category" asp-action="Index" class="list-group-item list-group-item-action"> Books </a>
                        </div>

                    <button class="btn btn-primary w-100">Apply Filters</button>

                </div>
            </aside>

            <main class="col-md-9 col-lg-10">
                @RenderBody()
            </main>

        </div>
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    }
    else
    {
        <div class="container mt-4">
            @RenderBody()
        </div>
    }

    <footer class="footer text-muted">
        <div class="container d-sm-inline-flex justify-content-center">
            &copy; 2026 - EGielda - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>