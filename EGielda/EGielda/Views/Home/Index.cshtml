@{
    ViewData["Title"] = "Home Page";
}

<h1>Welcome to EGielda</h1>
<p>One and only cheapest online store on the market.</p>

<div class="row">
    <div class="col-md-4">
        <a asp-controller="Product" asp-action="Index" class="text-decoration-none text-dark">
            <div class="card p-3 shadow-sm">
                <h5>Products</h5>
                <p>Browse available products</p>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Category" asp-action="Index" class="text-decoration-none text-dark">
            <div class="card p-3 shadow-sm">
                <h5>Categories</h5>
                <p>Explore product categories</p>
            </div>
        </a>
    </div>
</div>