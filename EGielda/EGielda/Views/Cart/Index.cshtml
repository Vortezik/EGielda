@model EGielda.Models.Cart
@{
    ViewData["Title"] = "Index";
    decimal total = 0;
}

<h2 class="mb-4">My Cart</h2>

@if (!Model.CartItems.Any())
{
    <div class="alert alert-info">
        Your cart is empty.
    </div>

    <a asp-controller="Product" asp-action="Index" class="btn btn-primary"> Browse Products </a>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Product</th>
                <th width="120">Price</th>
                <th width="170">Quantity</th>
                <th width="120">Total</th>
                <th width="120"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.CartItems)
            {
                var lineTotal = item.Product.Price * item.Quantity;
                total += lineTotal;

                <tr>
                    <td>
                        <strong>@item.Product.Name</strong>
                    </td>

                    <td>@item.Product.Price zł</td>

                    <td>
                        <a asp-action="Decrease" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"> - </a>

                        <span class="mx-2">@item.Quantity</span>

                        <a asp-action="Increase" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"> + </a>
                    </td>

                    <td>@lineTotal zł</td>

                    <td>
                        <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-sm btn-danger"> Remove </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end mt-4">
        <h4>Total: @total zł</h4>

        <form asp-action="Checkout" method="post">
            <button type="submit" class="btn btn-success mt-2"> Checkout </button>
        </form>
    </div>
}