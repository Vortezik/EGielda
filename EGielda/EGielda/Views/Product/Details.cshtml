@model EGielda.Models.Product
@{
    ViewData["Title"] = "Details";
}

<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" />
    </div>

    <div class="col-md-6">
        <h2>@Model.Name</h2>

        <p class="text-muted">@Model.Category?.Name</p>

        <p class="mt-3">@Model.Description</p>

        <h4 class="fw-bold mt-4">@Model.Price zł</h4>

        <div class="mt-4">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <button type="submit" class="btn btn-success">
                        Add to Cart
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="User" asp-action="Login" class="btn btn-primary"> Login to Add to Cart </a>
            }
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary"> Back </a>
        </div>
    </div>
</div>