@model IEnumerable<EGielda.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h1 class="mb-4">Products</h1> 

<div class="row align-items-stretch"> 
    @foreach (var product in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <div class="card product-card h-100 shadow-sm">
                <a asp-action="Details" asp-route-id="@product.Id">
                    <img src="@product.ImageUrl" class="card-img-top" />
                </a>
                <div class="card-body d-flex flex-column">
                    <h5>@product.Name</h5>
                    <div class="mt-auto">
                        <p class="fw-bold">@product.Price zł</p>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary w-100"> View </a>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />

                                <button type="submit" class="btn btn-success w-100"> Add to Cart </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="User" asp-action="Login" class="btn btn-outline-secondary w-100"> Login to Buy </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>